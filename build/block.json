{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "lexical-lode/lexical-lode-block",
  "version": "1.0.0",
  "title": "Lexical Lode",
  "category": "text",
  "icon": "editor-quote",
  "description": "Mine your site's blog posts for found poetry.",
  "textdomain": "lexical-lode",
  "attributes": {
    "format": {
      "type": "string",
      "default": "free_verse"
    },
    "lines": {
      "type": "array",
      "default": []
    },
    "lineCount": {
      "type": "number",
      "default": 14,
      "minimum": 1,
      "maximum": 50
    },
    "attribution": {
      "type": "string",
      "default": "hidden",
      "enum": [
        "hidden",
        "hover",
        "footnotes"
      ]
    },
    "postOrder": {
      "type": "string",
      "default": "random",
      "enum": [
        "random",
        "newest",
        "oldest"
      ]
    }
  },
  "supports": {
    "html": false,
    "align": true,
    "spacing": {
      "margin": true,
      "padding": true
    },
    "typography": {
      "fontSize": true,
      "lineHeight": true
    }
  },
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css"
}